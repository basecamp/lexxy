<p style="color: green"><%= notice %></p>

<div id="<%= dom_id @secret %>">
  <p>
    <strong>Title:</strong>
    <%= @secret.title %>
  </p>

  <p data-controller="code-highlight">
    <strong>Body:</strong>
    <%= @secret.body %>
  </p>
</div>

<div>
  <%= link_to "Edit this secret", edit_secret_path(@secret) %> |
  <%= link_to "Back to secrets", secrets_path %>

  <%= button_to "Destroy this secret", @secret, method: :delete %>
</div>
