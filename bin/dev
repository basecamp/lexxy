#!/usr/bin/env bash

# Kill any previous Rails server
for pidfile in tmp/pids/server.pid test/dummy/tmp/pids/server.pid; do
  if [ -f "$pidfile" ]; then
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      echo "Killing previous Rails server (PID: $pid)..."
      kill -9 "$pid" 2>/dev/null
      wait "$pid" 2>/dev/null
    fi
    rm -f "$pidfile"
  fi
done

# Kill anything still listening on port 3000
port_pid=$(lsof -ti tcp:3000 2>/dev/null)
if [ -n "$port_pid" ]; then
  echo "Killing process on port 3000 (PID: $port_pid)..."
  kill -9 $port_pid 2>/dev/null
fi

exec foreman start -f Procfile.dev -p 3000 "$@"
